.nprogress-custom-parent #nprogress .bar, .nprogress-custom-parent #nprogress .spinner { position: absolute; }

@-webkit-keyframes nprogress-spinner { 
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
